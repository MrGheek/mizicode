[Unit]
Description=Ollama inference server (for Mizi-Local)
Documentation=https://ollama.com
After=network.target

[Service]
Type=simple
User={{USER}}
ExecStart=/usr/local/bin/ollama serve
Restart=on-failure
RestartSec=3s
Environment=OLLAMA_HOST=0.0.0.0:11434
StandardOutput=append:{{MIZI_HOME}}/mizi-ollama.log
StandardError=append:{{MIZI_HOME}}/mizi-ollama.log

[Install]
WantedBy=multi-user.target
