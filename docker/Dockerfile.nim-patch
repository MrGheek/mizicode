FROM registry.fly.io/mizi-api:deployment-01KS5M5WVX4V24YNN0D6VMFPVM
RUN pip3 install --no-cache-dir httpx fastapi uvicorn
COPY docker/onstart.sh /opt/onstart.sh
COPY docker/nim-proxy.py /opt/nim-proxy.py
# claw-bridge.mjs: updated for Node 20 compat (ws polyfill) + MIZI_BRIDGE_URL support
COPY docker/claw-bridge.mjs /opt/claw-bridge.mjs
RUN chmod +x /opt/onstart.sh /opt/nim-proxy.py
