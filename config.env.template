# Mizi-Local configuration template
# Copy to ~/.mizi/config.env or set environment variables before starting.
# Zero cloud API keys required for local distribution.

# ── Distribution ──────────────────────────────────────────────────────────────
MIZI_DISTRIBUTION=local
NODE_ENV=production

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3000
API_PORT=4000

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Optional: override which model to use by default
# MIZI_DEFAULT_MODEL=qwen2.5-coder:7b

# ── Local database ────────────────────────────────────────────────────────────
# SQLite database path (created automatically on first boot)
MIZI_LOCAL_DB_PATH=~/.mizi/local.db

# ── Workspace ─────────────────────────────────────────────────────────────────
MIZI_LOCAL_WORKSPACE=~/.mizi/workspace
MIZI_LOCAL_MODELS_DIR=~/.mizi/models

# ── ACP (Agent Communication Protocol) ───────────────────────────────────────
# Local claw runner ACP endpoint (default: 5185)
ACP_PORT=5185
# ACP_BASE_URL=http://localhost:5185

# ── Hailo (optional — auto-detected) ─────────────────────────────────────────
# MIZI_HAILO_HEF_DIR=~/.mizi/hailo-models
# MIZI_HAILO_EMBEDDING_HEF=~/.mizi/hailo-models/sentence-transformer.hef
# MIZI_HAILO_EMBEDDING_DIM=384

# ── HuggingFace Hub (optional — for HF model downloads) ──────────────────────
# HF_TOKEN=hf_...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Memory ────────────────────────────────────────────────────────────────────
# MIZI_MEM_TOKEN is not required in local mode.
# Local memory uses SQLite; no remote vector DB needed.
