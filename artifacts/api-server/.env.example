# API Server environment variables
# Copy this file to .env and fill in the values.

# Port the API server listens on (required)
PORT=8080

# Directory where the memory SQLite database is stored.
# In production this MUST point to a mounted persistent volume so that
# memory data survives container restarts and redeployments.
#
# The server validates this directory at startup and will REFUSE TO START
# (with a clear error in the logs) if the path cannot be created or written to.
# This prevents silent data loss from a misconfigured or missing volume mount.
#
# Production (mounted volume): MEM_DATA_DIR=/data/memory
# Default (when unset): ~/omniql-memory
#
# See README.md for full volume mount requirements.
# Leave unset for local development; the server will use ~/omniql-memory automatically.
# MEM_DATA_DIR=/data/memory

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
