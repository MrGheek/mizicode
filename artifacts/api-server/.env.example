# API Server environment variables
# Copy this file to .env and fill in the values.

# Port the API server listens on (required)
PORT=8080

# Directory where the memory SQLite database is stored.
# In production this MUST point to a mounted persistent volume so that
# memory data survives container restarts and redeployments.
#
# The server validates this directory at startup and will REFUSE TO START
# (with a clear error in the logs) if the path cannot be created or written to.
# This prevents silent data loss from a misconfigured or missing volume mount.
#
# Production (mounted volume): MEM_DATA_DIR=/data/memory
# Default (when unset): ~/mizi-memory
#
# See README.md for full volume mount requirements.
# Leave unset for local development; the server will use ~/mizi-memory automatically.
# MEM_DATA_DIR=/data/memory

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# ── GitHub OAuth (single-operator model) ─────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers.
# Set the Authorization callback URL to: https://<your-domain>/api/auth/github/callback
#
# Required to enable "Sign in with GitHub" in the dashboard settings panel.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Optional: the public URL of the dashboard frontend. Used to redirect the
# browser back to the correct origin after OAuth completes. If omitted, the
# server falls back to the Referer/Origin header sent by the browser.
# DASHBOARD_URL=https://your-dashboard.example.com
