# ============================================================
# FLOATR API Server — environment variables / secrets
#
# Copy this file to .env for local development (never commit
# a populated .env).  On Fly.io, set these via:
#   fly secrets set KEY="value" --config artifacts/api-server/fly.toml
# ============================================================

# ------------------------------------
# Required — Database
# ------------------------------------

# PostgreSQL connection string.
# On Fly.io, created with:
#   fly postgres create --name floatr-db
#   fly postgres attach floatr-db --app floatr-api
# That attach command sets DATABASE_URL automatically.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ------------------------------------
# Required — Server
# ------------------------------------

# TCP port the Express server listens on (default 8080 on Fly.io).
PORT=8080

# ------------------------------------
# Required — Vast.ai
# ------------------------------------

# API key from https://vast.ai/console/account
VASTAI_API_KEY=your_vastai_api_key_here

# ------------------------------------
# Optional — AI / LLM providers
# ------------------------------------

# OpenAI-compatible API key used for ambient features and memory embeddings.
# On Replit this is provided by the AI Integrations proxy.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Base URL for the OpenAI-compatible endpoint.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# NVIDIA NIM API key (used for NIM catalog sync; omit to disable NIM features).
NVIDIA_NIM_API_KEY=nvapi-...

# Vultr Inference API key (optional — enables Vultr as a model provider).
VULTR_INFERENCE_API_KEY=

# Together AI API key (optional — enables Together.xyz as a model provider).
TOGETHER_API_KEY=

# DeepInfra API key (optional — enables DeepInfra as a model provider).
DEEPINFRA_API_KEY=

# ------------------------------------
# Optional — Safety / notifications
# ------------------------------------

# E-mail address to send safety alert notifications to (leave blank to disable).
SAFETY_EMAIL_TO=

# Webhook URL for safety e-mail delivery (e.g. a Make/Zapier HTTP endpoint).
SAFETY_EMAIL_WEBHOOK_URL=

# Bearer token for the safety webhook (optional auth header).
SAFETY_EMAIL_WEBHOOK_AUTH=

# ------------------------------------
# Optional — Ambient runner identity
# ------------------------------------

# User ID recorded as the operator in memory observations.
OMNIQL_MEM_USER_ID=operator

# Account ID used by the ambient scheduler (defaults to "default").
AMBIENT_ACCOUNT_ID=default

# ------------------------------------
# Optional — Tuning
# ------------------------------------

# Directory where the SQLite memory database is stored.
# Must match the Fly.io volume mount destination.
MEM_DATA_DIR=/data/memory

# Number of days to retain inactive lane claims before purging.
CLAIM_RETENTION_DAYS=7

# How often (milliseconds) to run the inactive claim purge job.
# Default: 3600000 (1 hour)
CLAIM_CLEANUP_INTERVAL_MS=3600000
